# skein — every skill reads its targets from here. Nothing is hardcoded.
#
# None of this is required to install skein. Each block is needed only by the
# skills that name it, and every skill states what it does when the block is
# missing — see the "Stack tools this reaches for" table at the top of each
# SKILL.md. A skill that cannot reach its target says so; none of them degrade
# into a silent success.

# --- knowledge graph: quipu / graph-extract / graph-report -------------------
# Required by those three. They have no offline mode, by design.
GRAPH_URL=http://graph.example.com           # Quipu HTTP endpoint
GRAPH_GROUP=my-ontology                      # graph partition to write into
GRAPH_NS=http://example.org/ontology/        # IRI base for your own entities & classes

# --- metrics: metrics-query, homelab-patrol, homelab-deploy ------------------
PROM_URL=http://prometheus.example.com:9090      # Prometheus HTTP API
ALERTMANAGER_URL=http://alerts.example.com:9093  # Alertmanager v2 API
# PROM_BEARER_TOKEN=                             # optional — Authorization: Bearer
PROM_TIMEOUT=10

# --- notifications: notify ---------------------------------------------------
# ntfy needs BOTH url and topic. Half a config is not a transport — notify
# counts it as unconfigured and exits 3 rather than pretending it sent anything.
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=ops-alerts
# NTFY_TOKEN=                                  # optional — Authorization: Bearer
NOTIFY_WEBHOOK_URL=https://chat.example.com/hooks/xxx  # Slack/Mattermost/Discord/IRC bridge
NOTIFY_WEBHOOK_KEY=text                        # "text" Slack+Mattermost, "content" Discord
NOTIFY_MIN_SEVERITY=debug                      # debug|info|warning|critical
# NOTIFY_PRIORITY_CRITICAL=5                   # override any severity -> ntfy priority
NOTIFY_TIMEOUT=10

# --- code search / data plane ------------------------------------------------
SEARCH_URL=http://search.example.com         # optional — remote bobbin server
DB_HOST=db.example.com                       # optional — data plane
BEADS_DB=your_issues_db                      # optional — issue tracker db

# --- dispatch-work -----------------------------------------------------------
# The preferred path is the `st` CLI, which carries its own config. These tune
# the bundled fallback engine only.
# DISPATCH_CONTEXT_HIGH_K=400                  # tokens before a pane is "high context"
# DISPATCH_UNRELATED_THRESHOLD=0.15            # keyword overlap below this = unrelated
# DISPATCH_TAIL_LINES=8                        # trailing lines triage judges
# DISPATCH_INFLIGHT="esc to interrupt|Running…"  # your runtime's busy markers
# DISPATCH_TMUX=tmux
# DISPATCH_BEADS_REPO=/path/to/repo
# DISPATCH_GH_REPO=owner/name
# DISPATCH_FILE_DIR=./work
